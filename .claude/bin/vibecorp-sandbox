#!/bin/bash
# vibecorp-sandbox — OS ディスパッチャ
#
# 目的:
#   OS を判定し、対応するサンドボックス機構を使って引数で指定された
#   コマンドを隔離実行する。Phase 1 (#309) で Darwin、Phase 2 (#310) で Linux を実装。
#
# 使い方:
#   vibecorp-sandbox <command> [args...]
#
#   コマンドの解決は sandbox 起動後の PATH に委ねる。
#
# 挙動:
#   - Darwin: sandbox-exec -f <profile> -D ... env VIBECORP_SANDBOXED=1 "$@"
#   - Linux:  bwrap <args from bwrap-args.sh> -- env VIBECORP_SANDBOXED=1 "$@"
#   - その他: stderr に未対応 OS メッセージを出して exit 69
#
# fail-closed 設計:
#   - bwrap / sandbox-exec 起動失敗時に passthrough しない
#   - exec 失敗（user namespace 無効・kernel ENOSYS・AppArmor 拒否等）はプロセス非ゼロ終了
#
# 終了コード規約（sysexits.h 準拠）:
#   - 0:  正常終了
#   - 1:  入力 / 環境バリデーション失敗（HOME / WORKTREE / TMPDIR の絶対パス検査等）/ bwrap 不在
#   - 64: 引数エラー（EX_USAGE。引数不足等の使い方違反）
#   - 69: 当該 OS 未対応（EX_UNAVAILABLE。macOS / Linux 以外）
#         「引数エラー（64）」と区別することで、呼び出し側は OS 不一致を引数誤りと誤認しない
#
# 参照: #293 / #309 / #310 / #514

set -euo pipefail

if [[ $# -lt 1 ]]; then
  echo "vibecorp-sandbox: 使い方: vibecorp-sandbox <command> [args...]" >&2
  exit 64
fi

# 自身のディレクトリを解決（sandbox profile を相対パスで特定するため）
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROFILE="${SCRIPT_DIR}/../sandbox/claude.sb"

OS="$(uname -s)"

# パス値の検証（sandbox-exec の -D 引数に渡す前に sanitize する）
#
# 目的:
#   $PWD / $HOME / $TMPDIR は外部（シェル・CI 環境・親プロセス）から汚染されうる。
#   これらを sandbox-exec の (param "KEY") に無検証で渡すと、
#   プロファイル内の `(subpath (param "WORKTREE"))` が `/` や `$HOME` 全体に展開され、
#   sandbox の書込境界が崩壊する。
#
# 参照: .claude/rules/shell.md「ファイル名に外部入力を使う場合」
validate_abs_path() {
  local value="$1"
  local name="$2"
  if [[ -z "$value" ]]; then
    echo "vibecorp-sandbox: $name が空です" >&2
    exit 1
  fi
  if [[ "$value" != /* ]]; then
    echo "vibecorp-sandbox: $name は絶対パスである必要があります: $value" >&2
    exit 1
  fi
  if [[ "$value" == "/" ]]; then
    echo "vibecorp-sandbox: $name をルート(/)にはできません: $value" >&2
    exit 1
  fi
  if [[ "$value" == *".."* ]]; then
    echo "vibecorp-sandbox: $name にパストラバーサル(..)が含まれています: $value" >&2
    exit 1
  fi
  # 空白・クォート・セミコロン・バックスラッシュ・バッククォート等の危険文字を拒否
  case "$value" in
    *[[:space:]]*|*\"*|*\'*|*\;*|*\|*|*\&*|*\`*|*\$*|*\\*)
      echo "vibecorp-sandbox: $name に危険文字が含まれています: $value" >&2
      exit 1
      ;;
  esac
}

# ディレクトリを正規化する（symlink を解決して物理パスを返す）
#
# 目的:
#   $PWD / $HOME / $TMPDIR が symlink 経由で別ディレクトリを指す場合でも、
#   sandbox 境界の判定を canonical path で行うため。
#   例: macOS の $TMPDIR は `/var/folders/.../T/` だが、これは `/private/var/...` の
#   symlink。両者を混在比較すると包含判定が崩れる。
canonicalize_dir() {
  local p="$1"
  local name="$2"
  if [[ -z "$p" ]]; then
    echo "vibecorp-sandbox: canonicalize_dir: $name が空です" >&2
    exit 1
  fi
  if [[ ! -d "$p" ]]; then
    echo "vibecorp-sandbox: $name のディレクトリが存在しません: $p" >&2
    exit 1
  fi
  (cd "$p" && pwd -P)
}

case "$OS" in
  Darwin)
    if [[ ! -f "$PROFILE" ]]; then
      echo "vibecorp-sandbox: sandbox プロファイルが見つかりません: $PROFILE" >&2
      exit 1
    fi

    # sandbox-exec に渡す前に WORKTREE / HOME / DARWIN_TMPDIR を検証
    # 1) raw 値の書式チェック（空文字 / 非絶対パス / ルート / .. / 危険文字）
    WORKTREE_RAW="$PWD"
    HOME_RAW="${HOME:-}"
    DARWIN_TMPDIR_RAW="${TMPDIR:-/tmp}"

    validate_abs_path "$WORKTREE_RAW" "WORKTREE"
    validate_abs_path "$HOME_RAW" "HOME"
    validate_abs_path "$DARWIN_TMPDIR_RAW" "DARWIN_TMPDIR"

    # 2) symlink を解決して canonical path に正規化
    #    symlink 経由で HOME を別ディレクトリに飛ばして sandbox 境界をすり抜ける攻撃を防ぐ
    WORKTREE_VALUE="$(canonicalize_dir "$WORKTREE_RAW" "WORKTREE")"
    HOME_VALUE="$(canonicalize_dir "$HOME_RAW" "HOME")"
    DARWIN_TMPDIR_VALUE="$(canonicalize_dir "$DARWIN_TMPDIR_RAW" "DARWIN_TMPDIR")"

    # 3) canonicalize 後の値も危険文字・ルートを再検証
    validate_abs_path "$WORKTREE_VALUE" "WORKTREE (canonicalized)"
    validate_abs_path "$HOME_VALUE" "HOME (canonicalized)"
    validate_abs_path "$DARWIN_TMPDIR_VALUE" "DARWIN_TMPDIR (canonicalized)"

    # 4) WORKTREE を HOME 自体にする設定は sandbox の書込境界を
    #    ホームディレクトリ全体に広げてしまうため拒否する
    if [[ "$WORKTREE_VALUE" == "$HOME_VALUE" ]]; then
      echo "vibecorp-sandbox: WORKTREE を HOME と同一にはできません: $WORKTREE_VALUE" >&2
      exit 1
    fi

    # 5) WORKTREE が HOME を包含する（WORKTREE=/Users、WORKTREE が HOME の祖先 等）設定は、
    #    (subpath (param "WORKTREE")) により ~/.ssh / ~/.aws / ~/.gnupg まで RW になるため拒否する
    case "${HOME_VALUE}/" in
      "${WORKTREE_VALUE}/"*)
        echo "vibecorp-sandbox: WORKTREE が HOME を包含しています: WORKTREE=$WORKTREE_VALUE, HOME=$HOME_VALUE" >&2
        exit 1
        ;;
    esac

    # macOS の sandbox-exec でコマンドを実行
    # - -f: プロファイルファイル
    # - -D KEY=VALUE: プロファイル内の (param "KEY") で参照される値
    # - env VIBECORP_SANDBOXED=1: 子プロセスに二重サンドボックス防止フラグを伝播
    #   （env var は信頼境界ではない。claude シム側で PPID 検証と AND 取って判定する）
    exec /usr/bin/sandbox-exec \
      -f "$PROFILE" \
      -D "WORKTREE=$WORKTREE_VALUE" \
      -D "HOME=$HOME_VALUE" \
      -D "DARWIN_TMPDIR=$DARWIN_TMPDIR_VALUE" \
      env VIBECORP_SANDBOXED=1 "$@"
    ;;
  Linux)
    BWRAP_ARGS_FILE="${SCRIPT_DIR}/../sandbox/bwrap-args.sh"
    # symlink チェック（Link Following 脆弱性対策）:
    # source 実行前に BWRAP_ARGS_FILE が symlink でないことを確認する。
    # install.sh の copy_isolation_templates は配置時に symlink を排除する
    # ガードを持つが、配置後に攻撃者制御の symlink へ差し替えられると、
    # source "$BWRAP_ARGS_FILE" 時に任意シェルコードが実行される経路となる。
    # 既知制約「bwrap-args.sh の TOCTOU」とは別の Link Following 攻撃面のため
    # 本スクリプトでも独立に拒否する（CISO メタレビュー 2026-05-16、Issue #310）。
    if [[ ! -f "$BWRAP_ARGS_FILE" || -L "$BWRAP_ARGS_FILE" ]]; then
      echo "vibecorp-sandbox: bwrap-args.sh が見つからないか symlink です: $BWRAP_ARGS_FILE" >&2
      exit 1
    fi

    # bwrap 起動失敗の区分別 preflight チェック（fail-closed）
    # Issue #579: 4 区分（A/B/C/D）に分けて失敗原因を CEO に提示する。
    #
    #   A: バイナリ不在            → command -v bwrap で検出
    #   B: バイナリ破損・権限      → bwrap --version で検出
    #   C: user namespace 制限     → bwrap --unshare-pid ... -- /bin/sh -c : で検出
    #   D: kernel/distro 固有問題  → 非 exec 化した bwrap の終了コードで検出
    #
    # メッセージはシングルクォートまたは printf でリテラル出力する（外部入力由来の
    # コマンド出力が stderr に混入する経路を物理的に排除する）。
    # 内部整数変数（${status} など）はダブルクォート内で展開してよい。

    # 区分 A: バイナリ不在
    # 不在時は install.sh が distro 別の案内を出すが、本スクリプト単独実行経路の保険として
    # ここでも日本語メッセージで exit 1 する。passthrough は絶対にしない。
    if ! command -v bwrap >/dev/null 2>&1; then
      echo 'vibecorp-sandbox: bwrap (bubblewrap) が見つかりません。隔離レイヤには bwrap が必要です。' >&2
      echo '  Debian/Ubuntu: sudo apt-get install bubblewrap' >&2
      echo '  Fedora/RHEL:   sudo dnf install bubblewrap' >&2
      echo '  Alpine:        sudo apk add bubblewrap' >&2
      exit 1
    fi

    # 区分 B: バイナリ破損 / 実行権限の問題
    # `bwrap --version` で起動可否のみを確認する。バイナリが存在しても権限不足や
    # 共有ライブラリ欠落で起動できないケースをここで区別する。
    if ! bwrap --version >/dev/null 2>&1; then
      echo 'vibecorp-sandbox: bwrap バイナリは存在しますが `--version` で起動失敗しました。バイナリ破損または実行権限の問題です。' >&2
      echo '  再インストール案内:' >&2
      echo '    Debian/Ubuntu: sudo apt-get install --reinstall bubblewrap' >&2
      echo '    Fedora/RHEL:   sudo dnf reinstall bubblewrap' >&2
      echo '    Alpine:        sudo apk add --upgrade bubblewrap' >&2
      echo '  実行権限の確認: ls -lah "$(command -v bwrap)"' >&2
      exit 1
    fi

    # 区分 C: user namespace 制限
    # `bwrap --unshare-pid --proc /proc --dev /dev --tmpfs /tmp -- /bin/sh -c :` で
    # user namespace の動作確認のみを行う。/bin/true ではなく /bin/sh -c : を使うのは、
    # NixOS 等の非標準 /bin レイアウト distro で /bin/true 不在による誤検知を避けるため
    # （/bin/sh は POSIX 必須、`:` は組込みコマンド）。
    if ! bwrap --unshare-pid --proc /proc --dev /dev --tmpfs /tmp -- /bin/sh -c : >/dev/null 2>&1; then
      echo 'vibecorp-sandbox: user namespace で bwrap が動作しません。' >&2
      echo '  切り分け手順:' >&2
      echo '    sysctl kernel.unprivileged_userns_clone   # 0 なら unprivileged user namespace が無効' >&2
      echo '    dmesg | grep -i bwrap                     # kernel 拒否ログ' >&2
      echo '    aa-status; dmesg | grep -i apparmor       # AppArmor 制限の確認' >&2
      echo '    getenforce                                 # SELinux モードの確認' >&2
      echo '  GHA `ubuntu-latest` (Ubuntu 24.04) / Docker コンテナでは既知制約（AppArmor 4.0 の unprivileged_userns 制限）。' >&2
      echo '  詳細は docs/SECURITY.md の「Linux (Phase 2) 固有制約」および「Linux 診断手段」を参照してください。' >&2
      exit 1
    fi

    # macOS 同様に WORKTREE / HOME / LINUX_TMPDIR を validate + canonicalize する
    # 1) raw 値の書式チェック（空文字 / 非絶対パス / ルート / .. / 危険文字）
    WORKTREE_RAW="$PWD"
    HOME_RAW="${HOME:-}"
    LINUX_TMPDIR_RAW="${TMPDIR:-/tmp}"

    validate_abs_path "$WORKTREE_RAW" "WORKTREE"
    validate_abs_path "$HOME_RAW" "HOME"
    validate_abs_path "$LINUX_TMPDIR_RAW" "LINUX_TMPDIR"

    # 2) symlink を解決して canonical path に正規化
    #    symlink 経由で HOME を別ディレクトリに飛ばして bwrap bind 境界をすり抜ける攻撃を防ぐ
    WORKTREE_VALUE="$(canonicalize_dir "$WORKTREE_RAW" "WORKTREE")"
    HOME_VALUE="$(canonicalize_dir "$HOME_RAW" "HOME")"
    LINUX_TMPDIR_VALUE="$(canonicalize_dir "$LINUX_TMPDIR_RAW" "LINUX_TMPDIR")"

    # 3) canonicalize 後の値も危険文字・ルートを再検証
    validate_abs_path "$WORKTREE_VALUE" "WORKTREE (canonicalized)"
    validate_abs_path "$HOME_VALUE" "HOME (canonicalized)"
    validate_abs_path "$LINUX_TMPDIR_VALUE" "LINUX_TMPDIR (canonicalized)"

    # 4) WORKTREE を HOME 自体にする設定は bwrap の書込境界を
    #    ホームディレクトリ全体に広げてしまうため拒否する（macOS と同じロジック）
    if [[ "$WORKTREE_VALUE" == "$HOME_VALUE" ]]; then
      echo "vibecorp-sandbox: WORKTREE を HOME と同一にはできません: $WORKTREE_VALUE" >&2
      exit 1
    fi

    # 5) WORKTREE が HOME を包含する（WORKTREE ⊇ HOME。例: WORKTREE=/home、HOME=/home/user）設定は、
    #    (bind WORKTREE) により ~/.ssh / ~/.aws / ~/.gnupg まで RW になるため拒否する（macOS と同じロジック）。
    #    判定式: ${HOME_VALUE}/ が ${WORKTREE_VALUE}/* で始まる場合に HOME が WORKTREE の配下にあると判定される
    case "${HOME_VALUE}/" in
      "${WORKTREE_VALUE}/"*)
        echo "vibecorp-sandbox: WORKTREE が HOME を包含しています: WORKTREE=$WORKTREE_VALUE, HOME=$HOME_VALUE" >&2
        exit 1
        ;;
    esac

    # bwrap-args.sh を source して BWRAP_ARGS 配列を組み立て
    export WORKTREE_VALUE HOME_VALUE LINUX_TMPDIR_VALUE
    # shellcheck source=../sandbox/bwrap-args.sh
    source "$BWRAP_ARGS_FILE"

    # bwrap を起動（fail-closed）
    # - "${BWRAP_ARGS[@]}" は bwrap-args.sh が組み立てた配列
    # - --setenv VIBECORP_SANDBOXED 1 は bwrap-args.sh 内で追加済み
    # - env VIBECORP_SANDBOXED=1 は二重に取りこぼし防止（信頼境界は claude シム側の
    #   is_inside_sandbox の PPID 検証と AND で評価）
    #
    # Issue #579: 区分 D（preflight 通過後の kernel/distro 固有失敗）を catch するため、
    # 従来の `exec bwrap ...` を非 exec 化する。shell が bwrap の終了を待ち、終了コードが
    # 非 0 の場合に区分 D メッセージを stderr に出力して同じ終了コードで exit する。
    # bwrap 自体の引数・隔離挙動は変わらない。fail-closed は維持（passthrough しない）。
    # `set -e` 下で bwrap が非 0 で終わると、status=$? の取得前に shell が exit してしまう。
    # `|| status=$?` で set -e を抑制し、終了コードを確実に取得する。
    status=0
    bwrap "${BWRAP_ARGS[@]}" -- env VIBECORP_SANDBOXED=1 "$@" || status=$?
    if [[ "$status" -ne 0 ]]; then
      # 区分 D: kernel/distro 固有問題（preflight 通過後の失敗）
      # $status は内部生成の整数変数のためダブルクォート内で展開してよい。
      echo "vibecorp-sandbox: bwrap の preflight は通過しましたが、本番起動で exit code ${status} で失敗しました。kernel / distro 固有の問題の可能性があります。" >&2
      echo '  詳細は docs/SECURITY.md の「Linux 診断手段」の区分 D 診断手順を参照してください。' >&2
      exit "$status"
    fi
    exit 0
    ;;
  *)
    # exit 69 (EX_UNAVAILABLE): 当該 OS 向け実装が未提供。引数エラー（64）とは別軸。
    echo "vibecorp-sandbox: 未対応 OS: $OS（Phase 2 以降で検討）。" >&2
    exit 69
    ;;
esac
